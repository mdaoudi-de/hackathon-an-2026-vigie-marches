# Copier ce fichier en .env et ajuster si besoin. Toutes les variables sont FACULTATIVES :
# `docker compose up --build` fonctionne sans .env.

# Clé API Anthropic pour la génération du rapport d'aide à la décision.
# Sans clé, l'application fonctionne ; seul le bouton « Générer le rapport » renvoie un message.
ANTHROPIC_API_KEY=

# Mode d'ingestion des DECP (par défaut : --decp-remote, léger et rapide) :
#   laisser cette ligne commentée -> --decp-remote : vue DuckDB sur le Parquet distant (ingestion quasi instantanée).
#   INGEST_ARGS=" "  (une espace)  -> téléchargement local du Parquet (~200 Mo) : base 100 % autonome.
# INGEST_ARGS=--decp-remote

# Mettre à 1 pour relancer l'ingestion même si la base existe déjà (rafraîchir les données).
FORCE_INGEST=0

# URL de l'API vue depuis le NAVIGATEUR (port publié sur l'hôte). Figée au build du front.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mode démo hors-ligne de l'API (sert les fixtures des 3 cas, sans réseau) : 1 pour activer.
VIGIE_OFFLINE=0
